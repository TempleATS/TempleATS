# Database
DATABASE_URL=postgresql://temple:temple@localhost:5432/temple_ats?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-random-secret

# Server
PORT=8080

# CORS (comma-separated origins, defaults to localhost:5173 and localhost:8080)
# CORS_ORIGINS=https://ats.example.com

# Rate limiting (defaults: 10 req/s, burst 20)
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BURST=20

# File storage (defaults to local disk at ./uploads)
# STORAGE_TYPE=s3
# S3_BUCKET=my-ats-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com  # for DO Spaces, MinIO, etc.
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_KEY_PREFIX=uploads/

# SSO via OIDC (disabled if SSO_ISSUER is not set)
# SSO_ISSUER=https://accounts.google.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=https://ats.example.com/api/auth/sso/callback
